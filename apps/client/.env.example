# Local: copy to .env →  cp .env.example .env
#
# Vercel (required or the client ships with empty Supabase config):
#   Dashboard → your project → Settings → Environment Variables
#   Add BOTH keys below for Production (and Preview if you use preview URLs).
#   Values: Supabase → Project Settings → API → Project URL + anon public key.
#   Redeploy after saving (Vite bakes VITE_* in at `vite build` time).
#
# Browser: session id + nickname are kept in sessionStorage (one profile per tab).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Never put the service role key here or in any VITE_* variable.
# Set SUPABASE_SERVICE_ROLE_KEY only in Supabase → Edge Functions → Secrets for `room-api`.
