# Copy to .env for local dev: cp .env.example .env
# Vercel: set the same keys in Project Settings → Environment Variables (no file committed).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Never put the service role key here or in any VITE_* variable.
# Set SUPABASE_SERVICE_ROLE_KEY only in Supabase → Edge Functions → Secrets for `room-api`.
